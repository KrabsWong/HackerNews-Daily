# HackerNews Daily 环境变量配置
# 复制此文件为 .env 并填写实际值

# =============================================================================
# LLM 提供商配置（必填）
# =============================================================================
# 可选值: deepseek, openrouter
LLM_PROVIDER=deepseek

# DeepSeek API Key（如果使用 DeepSeek）
LLM_DEEPSEEK_API_KEY=your-deepseek-api-key

# OpenRouter API Key（如果使用 OpenRouter）
# LLM_OPENROUTER_API_KEY=your-openrouter-api-key
# LLM_OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# =============================================================================
# Jina AI 爬虫配置（必填）
# =============================================================================
# Jina AI Reader API Key
# 获取地址: https://jina.ai/reader/
# 免费版: 500 RPM
JINA_API_KEY=your-jina-api-key

# =============================================================================
# GitHub 发布配置（必填）
# =============================================================================
# GitHub Personal Access Token (需要 repo 权限)
GITHUB_TOKEN=your-github-token

# 目标仓库 (格式: owner/repo)
TARGET_REPO=your-username/your-repo

# 目标分支（默认 main）
TARGET_BRANCH=main

# =============================================================================
# Telegram 发布配置（可选）
# =============================================================================
# 是否启用 Telegram 发布
TELEGRAM_ENABLED=false

# Telegram Bot Token（如果启用）
# TELEGRAM_BOT_TOKEN=your-bot-token

# Telegram Channel ID（如果启用）
# TELEGRAM_CHANNEL_ID=@your-channel

# =============================================================================
# 内容过滤配置（可选）
# =============================================================================
# 是否启用敏感内容过滤
CONTENT_FILTER_ENABLED=false

# 过滤敏感级别: low, medium, high
# CONTENT_FILTER_SENSITIVITY=medium
