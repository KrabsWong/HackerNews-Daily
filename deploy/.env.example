# HackerNews Daily 环境变量配置

# =============================================================================
# 必填配置
# =============================================================================

# Jina.ai 爬虫 API Key
# 获取地址: https://jina.ai/reader/
JINA_API_KEY=your-jina-api-key

# DeepSeek LLM API Key
# 获取地址: https://platform.deepseek.com/
LLM_DEEPSEEK_API_KEY=your-deepseek-api-key

# GitHub Personal Access Token (需要 repo 权限)
# 获取地址: https://github.com/settings/tokens
GITHUB_TOKEN=your-github-token

# 目标仓库 (格式: owner/repo)
TARGET_REPO=your-username/your-repo

# =============================================================================
# 可选配置
# =============================================================================

# 目标分支（默认 main）
TARGET_BRANCH=main

# 文章数量（默认 30）
HN_STORY_LIMIT=30

# 摘要最大字数（默认 300）
SUMMARY_MAX_LENGTH=300

# =============================================================================
# Telegram 发布（可选）
# =============================================================================

# 是否启用 Telegram 发布
TELEGRAM_ENABLED=false

# Telegram Bot Token（如果启用）
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram Channel ID（如果启用）
# 公开频道: @频道名  私密频道: 数字ID
# TELEGRAM_CHANNEL_ID=@your-channel
